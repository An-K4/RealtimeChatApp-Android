<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RealtimeChatApp" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- Theme for Splash Screen -->
    <style name="Theme.RealtimeChatApp.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_splash</item>
        <!-- After the splash screen, it will transition to the main theme -->
        <item name="postSplashScreenTheme">@style/Theme.RealtimeChatApp</item>
    </style>
</resources>